{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BMU Inference Output Schema v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp_ms",
    "battery_index",
    "model_version",
    "advisory_level",
    "data_quality"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "battery_index": {
      "type": "integer",
      "minimum": 0,
      "maximum": 15
    },
    "model_version": {
      "type": "string"
    },
    "soh_percent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "rul_cycles": {
      "type": "number",
      "minimum": 0
    },
    "rul_days_estimated": {
      "type": "number",
      "minimum": 0
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "advisory_level": {
      "type": "string",
      "enum": ["info", "warning", "critical"]
    },
    "data_quality": {
      "type": "string",
      "enum": ["ok", "degraded", "invalid"]
    },
    "drift_flag": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
