          "datasource": {
            "type": "influxdb",
            "uid": "bfhrzlhskqhoge"
          },
          "query": "voltages = from(bucket: \"bmu\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\" and r._field == \"v_mv\")\n  |> group(columns: [\"bat\"])\n  |> last()\n  |> keep(columns: [\"bat\", \"_value\"])\n  |> rename(columns: {_value: \"voltage_mv\"})\n\ncurrents = from(bucket: \"bmu\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\" and r._field == \"i_a\")\n  |> group(columns: [\"bat\"])\n  |> last()\n  |> keep(columns: [\"bat\", \"_value\"])\n  |> rename(columns: {_value: \"current_a\"})\n\nstates = from(bucket: \"bmu\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\" and r._field == \"state\")\n  |> group(columns: [\"bat\"])\n  |> last()\n  |> keep(columns: [\"bat\", \"_value\"])\n  |> rename(columns: {_value: \"state\"})\n\njoin(tables: {v: voltages, c: currents}, on: [\"bat\"])\n  |> join(tables: {j: _, s: states}, on: [\"bat\"])\n  |> group()\n  |> sort(columns: [\"bat\"])",
          "refId": "A"
        }
      ],
