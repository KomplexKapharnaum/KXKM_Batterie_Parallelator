      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
      "fieldConfig": {
        "defaults": {
          "unit": "watth",
          "color": { "mode": "fixed", "fixedColor": "#FFD600" }
        }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
        "query": "from(bucket: \"bmu\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"solar\" and r._field == \"yield\")\n  |> aggregateWindow(every: 1h, fn: max, createEmpty: false)"
