      "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
      "fieldConfig": {
        "defaults": {
          "unit": "watth",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "dark-yellow", "value": null }, { "color": "green", "value": 500 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
        "query": "from(bucket: \"bmu\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"solar\" and r._field == \"yield\")\n  |> last()"
      }]
    },
    {
      "id": 7,
      "title": "PV Power Current",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "max": 500,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "dark-red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 200 }] }
