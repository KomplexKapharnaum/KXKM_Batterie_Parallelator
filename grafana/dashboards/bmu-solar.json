{
  "id": null,
  "uid": "bmu-solar-victron",
  "title": "BMU - Solar SmartSolar",
  "tags": ["bmu", "kxkm", "solar", "victron"],
  "timezone": "browser",
  "schemaVersion": 39,
  "style": "dark",
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "PV Power",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "fixed", "fixedColor": "#FFD600" },
          "custom": { "fillOpacity": 30, "gradientMode": "scheme", "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "calcs": ["last", "max", "mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
        "query": "from(bucket: \"bmu\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"solar\" and r._field == \"ppv\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
      }]
    },
    {
      "id": 2,
      "title": "PV Voltage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "color": { "mode": "fixed", "fixedColor": "#00AAFF" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
        "query": "from(bucket: \"bmu\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"solar\" and r._field == \"vpv\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
      }]
    },
    {
      "id": 3,
      "title": "Battery Voltage (MPPT)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "color": { "mode": "fixed", "fixedColor": "#00FF66" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "green", "value": 25 },
              { "color": "yellow", "value": 29 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
        "query": "from(bucket: \"bmu\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"solar\" and r._field == \"vbat\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
      }]
    },
    {
      "id": 4,
      "title": "Battery Current (MPPT)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "color": { "mode": "fixed", "fixedColor": "#00FFCC" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
        "query": "from(bucket: \"bmu\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"solar\" and r._field == \"ibat\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
      }]
    },
    {
      "id": 5,
      "title": "MPPT State",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFF", "color": "dark-red" }, "3": { "text": "BULK", "color": "orange" }, "4": { "text": "ABSORPTION", "color": "yellow" }, "5": { "text": "FLOAT", "color": "green" }, "7": { "text": "EQUALIZE", "color": "blue" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "dark-red", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "influxdb", "uid": "bfhrzlhskqhoge" },
        "query": "from(bucket: \"bmu\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"solar\" and r._field == \"cs\")\n  |> last()"
      }]
    },
    {
