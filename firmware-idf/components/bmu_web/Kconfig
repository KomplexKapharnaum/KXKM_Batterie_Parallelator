menu "BMU Web Server"
    config BMU_WEB_ADMIN_TOKEN
        string "Admin token for mutation routes"
        default ""
        help
            Token required for POST /api/battery/switch_on|off.
            Empty = mutations disabled (fail-closed).
    config BMU_WEB_MAX_RATE_SLOTS
        int "Rate limiter slot count"
        default 16
    config BMU_WEB_RATE_MAX_REQUESTS
        int "Max requests per window"
        default 10
    config BMU_WEB_RATE_WINDOW_MS
        int "Rate limit window (ms)"
        default 10000
endmenu
