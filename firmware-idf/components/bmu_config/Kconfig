menu "BMU Protection Config"

    config BMU_MIN_VOLTAGE_MV
        int "Seuil sous-tension (mV)"
        default 24000

    config BMU_MAX_VOLTAGE_MV
        int "Seuil sur-tension (mV)"
        default 30000

    config BMU_MAX_CURRENT_MA
        int "Seuil sur-courant (mA)"
        default 10000

    config BMU_VOLTAGE_DIFF_MV
        int "Tolerance desequilibre (mV)"
        default 1000

    config BMU_RECONNECT_DELAY_MS
        int "Delai reconnexion (ms)"
        default 10000

    config BMU_NB_SWITCH_MAX
        int "Coupures max avant verrouillage"
        default 5

    config BMU_OVERCURRENT_FACTOR
        int "Facteur surcourant critique (x1000)"
        default 1400
        help
            ERROR si |I| > (factor/1000) * max_current. 1.4 = 1400.
            Audit H7 : abaissé de 2.0 à 1.4 pour une coupure ferme plus tôt
            (la fenêtre 1.0×–facteur× n'est que déconnexion réversible).
            Valeur par défaut sûre — à valider selon MOSFET/chimie.

    config BMU_LOOP_PERIOD_MS
        int "Periode boucle protection (ms)"
        default 500

    config BMU_DEVICE_NAME
        string "Nom du BMU (identifiant unique par installation)"
        default "kxkm-bmu"
        help
            Nom utilise pour le BLE advertising, le topic MQTT (bmu/{name}/battery/N),
            et le tag InfluxDB. Exemples: gocab, k-led1, k-led2, tender, kryole.

endmenu
