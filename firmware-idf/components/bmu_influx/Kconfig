menu "BMU InfluxDB"
    config BMU_INFLUX_DIRECT_ENABLED
        bool "Enable direct InfluxDB writes (line-protocol over HTTP)"
        default n
        help
            Si désactivé (défaut), la télémétrie passe uniquement par MQTT
            (pont Telegraf → InfluxDB). Activez pour conserver l'écriture
            directe firmware → InfluxDB (redondante avec le chemin MQTT,
            mais autonome + persistance offline via bmu_influx_store).

    config BMU_INFLUX_URL
        string "InfluxDB URL"
        default "http://kxkm-ai:8086"
    config BMU_INFLUX_ORG
        string "InfluxDB Organization"
        default "kxkm"
    config BMU_INFLUX_BUCKET
        string "InfluxDB Bucket"
        default "bmu"
    config BMU_INFLUX_TOKEN
        string "InfluxDB API Token"
        default ""
    config BMU_INFLUX_BUFFER_SIZE
        int "Write buffer size (lines)"
        default 20
endmenu
